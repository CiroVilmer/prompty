{
  "$schema": "https://schema.railpack.com",
  "steps": {
    "install": {
      "inputs": [{ "source": "requirements.txt" }],
      "commands": [
        "python -m pip install fastapi uvicorn pydantic python-dotenv anthropic 'dspy-ai>=2.5' httpx"
      ]
    }
  },
  "deploy": {
    "startCommand": "python -m uvicorn apps.api.main:app --host 0.0.0.0 --port $PORT"
  }
}
