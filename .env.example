# ─── Database ────────────────────────────────────────────────────────────────
# Connection string for your database (Prisma / Drizzle)
# Examples:
#   PostgreSQL: postgresql://user:password@localhost:5432/prompty
#   SQLite (dev): file:./dev.db
DATABASE_URL="postgresql://user:password@localhost:5432/prompty"

# ─── Authentication ───────────────────────────────────────────────────────────
# Random secret used to sign session tokens / JWTs.
# Generate with: openssl rand -base64 32
AUTH_SECRET="change-me-generate-a-random-secret"

# ─── AI / LLM ────────────────────────────────────────────────────────────────
# Anthropic API key for Claude models (used by the /api/optimize route)
ANTHROPIC_API_KEY="sk-ant-..."

# ─── App ─────────────────────────────────────────────────────────────────────
# Public base URL of the deployed app (no trailing slash)
# Local: http://localhost:3000
# Production: https://prompty.vercel.app
NEXT_PUBLIC_APP_URL="http://localhost:3000"
